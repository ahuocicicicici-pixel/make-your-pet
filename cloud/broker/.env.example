# Coco broker 环境变量。复制为 .env 填好后:  node --env-file=.env src/pet-server.js
# .env 已被 gitignore，绝不入仓。

# —— 必填 ——
COCO_PET_TOKEN=换成一串随机长字符串      # 桌宠与 broker 之间的鉴权，桌宠 link.config 的 token 要一致
OPENCLAW_CLI=/path/to/openclaw/dist/index.js   # 你的 OpenClaw CLI 入口(用于跑 agent 回话)
COCO_WORKSPACE=/path/to/.openclaw/workspace    # 放了 SOUL/AGENTS/people.json 的 workspace

# —— 身份/路由 ——
COCO_PET_OWNER=owner1                     # 本 broker 服务的人(对应 people.json 的 key)
COCO_PET_USER_LABEL=主人                  # 转达系统提醒时怎么称呼
COCO_PET_SESSION=agent:main:pet           # OpenClaw 会话 key(每个宠物/人用不同的)
COCO_PET_PORT=18790                       # broker 监听端口(127.0.0.1)

# —— 提醒投递(deliver.js) ——
OPENCLAW_BIN=openclaw                     # openclaw 可执行(在 PATH 上就填 openclaw)
OPENCLAW_WEIXIN_ACCOUNT=你的BOT账号-im-bot # 默认发信账号(也可在 people.json 每人单独指定)

# —— 可选:双人互相转达(各自起一个 broker) ——
# COCO_PEER_PET_URL=http://127.0.0.1:18791/coco/pet
# COCO_PEER_PET_TOKEN=对方broker的token
# COCO_PEER_LABEL=对方

# —— 可选:生活时间轴(timeline-for-agent，独立 AGPL 项目；不填则关闭) ——
# COCO_TL_DIR=/path/to/timeline-for-agent
# COCO_PET_TL_STATE=/path/to/.timeline-pet
# COCO_REAL_TL_STATE=/path/to/.timeline-real

# —— 可选:训记(Xunji)运动数据 ——
# XUNJI_API_KEY=你的key
